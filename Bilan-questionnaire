        <div class="pill" data-field="sexe" data-val="Homme" onclick="togglePill(this)">Homme</div>
        <div class="pill" data-field="sexe" data-val="Femme" onclick="togglePill(this)">Femme</div>
        <div class="pill" data-field="sexe" data-val="Autre" onclick="togglePill(this)">Autre</div>
      </div>
    </div>
  </div>

  <div class="grid2">
    <div class="field"><label>Taille (cm)</label><input type="number" id="taille" placeholder="Ex : 175"></div>
