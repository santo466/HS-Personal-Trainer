<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bilan Offert — HS Personal Trainer</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --gold:#C9A84C; --gold-light:#E2C06A; --gold-dark:#8A6A22;
  --gold-dim:rgba(201,168,76,0.12);
  --black:#080808; --dark:#101010; --card:#141414;
  --border:rgba(201,168,76,0.18); --border2:#222;
  --text:#F0EAD6; --muted:rgba(255,255,255,0.45);
}
body { background:var(--black); color:var(--text); font-family:'Montserrat',sans-serif; min-height:100vh; }

/* HEADER */
.header {
  background:var(--black); border-bottom:1px solid var(--border);
  padding:14px 24px; display:flex; align-items:center; justify-content:space-between;
  position:sticky; top:0; z-index:50;
}
.logo { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:700; color:var(--text); letter-spacing:2px; }
.logo span { color:var(--gold); font-style:italic; }

/* PROGRESS */
.progress-wrap { padding:20px 24px 0; max-width:480px; margin:0 auto; }
.progress-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
.progress-label { font-size:10px; letter-spacing:3px; text-transform:uppercase; color:var(--gold); font-weight:600; }
.progress-fraction { font-size:10px; color:var(--muted); letter-spacing:1px; }
.progress-bar { height:3px; background:rgba(255,255,255,0.08); border-radius:2px; overflow:hidden; }
.progress-fill { height:100%; background:linear-gradient(to right, var(--gold-dark), var(--gold)); border-radius:2px; transition:width 0.5s cubic-bezier(0.4,0,0.2,1); }

/* SCREENS */
.screen { display:none; max-width:480px; margin:0 auto; padding:24px; animation:fadeUp 0.4s ease; }
.screen.active { display:block; }

@keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }

/* THANK YOU SCREEN */
.thankyou-icon { width:56px; height:56px; border-radius:50%; border:1px solid var(--gold); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; }
.thankyou-icon svg { width:24px; height:24px; }
.thankyou-title { font-family:'Cormorant Garamond',serif; font-size:32px; font-weight:600; color:var(--text); margin-bottom:12px; text-align:center; }
.thankyou-text { font-size:13px; line-height:1.9; color:var(--muted); text-align:center; margin-bottom:28px; }
.divider { width:50px; height:1px; background:linear-gradient(to right,transparent,var(--gold),transparent); margin:0 auto 28px; }

/* STEP HEADER */
.step-eyebrow { font-size:9px; letter-spacing:4px; text-transform:uppercase; color:var(--gold); opacity:0.8; margin-bottom:8px; }
.step-title { font-family:'Cormorant Garamond',serif; font-size:30px; font-weight:600; color:var(--text); margin-bottom:4px; }
.step-sub { font-size:12px; color:var(--muted); font-weight:300; margin-bottom:24px; }

/* FIELDS */
.field { display:flex; flex-direction:column; gap:6px; margin-bottom:14px; }
.field label { font-size:9px; font-weight:700; letter-spacing:3px; color:rgba(201,168,76,0.85); text-transform:uppercase; }
.field input, .field select, .field textarea {
  background:#0f0f0f; border:1px solid var(--border2); border-radius:3px;
  padding:12px 14px; color:#ffffff; font-size:13px; font-weight:400;
  font-family:'Montserrat',sans-serif; outline:none; width:100%;
  transition:border-color 0.2s;
  -webkit-appearance:none;
}
.field input:focus, .field select:focus, .field textarea:focus { border-color:var(--gold); }
.field textarea { min-height:72px; resize:none; }
.field select { color:#ffffff; background:#0f0f0f; }
.field select option { background:#141414; color:#fff; }

.grid2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }

/* RADIO PILLS */
.pills { display:flex; flex-wrap:wrap; gap:7px; }
.pill {
  background:#0f0f0f; border:1px solid var(--border2); border-radius:20px;
  padding:8px 14px; font-size:11px; color:var(--muted); font-weight:500;
  cursor:pointer; transition:all 0.2s; -webkit-user-select:none; user-select:none;
}
.pill.active { background:var(--gold); color:#000; border-color:var(--gold); font-weight:700; }

/* SCALE */
.scale { display:flex; gap:5px; }
.scale-btn {
  flex:1; background:#0f0f0f; border:1px solid var(--border2); border-radius:3px;
  padding:9px 4px; text-align:center; font-size:12px; font-weight:500;
  color:rgba(255,255,255,0.7); cursor:pointer;
  transition:all 0.2s; -webkit-user-select:none; user-select:none;
}
.scale-btn.active { background:var(--gold); color:#000; border-color:var(--gold); font-weight:700; }
.scale-labels { display:flex; justify-content:space-between; margin-top:4px; }
.scale-labels span { font-size:9px; color:var(--muted); }

/* OBJ GRID */
.obj-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; }
.obj-card {
  background:#0f0f0f; border:1px solid var(--border2); border-radius:4px;
  padding:14px 8px; text-align:center; cursor:pointer;
  transition:all 0.2s; -webkit-user-select:none; user-select:none;
}
.obj-card .lbl { font-size:10px; color:rgba(255,255,255,0.65); font-weight:600; letter-spacing:0.5px; text-transform:uppercase; line-height:1.4; }
.obj-card.active { background:var(--gold-dim); border-color:var(--gold); }
.obj-card.active .lbl { color:var(--gold); }

/* SECTION LABEL */
.section-label { font-size:9px; letter-spacing:3px; text-transform:uppercase; color:var(--gold); font-weight:700; margin:20px 0 10px; opacity:0.8; }

/* NAVIGATION */
.nav-btns { display:flex; gap:10px; margin-top:28px; }
.btn-next {
  flex:1; background:var(--gold); color:#000; border:none;
  font-family:'Montserrat',sans-serif; font-size:11px; font-weight:700;
  letter-spacing:3px; text-transform:uppercase; padding:15px;
  border-radius:3px; cursor:pointer; transition:background 0.2s;
}
.btn-next:hover { background:var(--gold-light); }
.btn-back {
  background:transparent; color:var(--gold); border:1px solid var(--border);
  font-family:'Montserrat',sans-serif; font-size:11px; font-weight:600;
  letter-spacing:2px; text-transform:uppercase; padding:15px 18px;
  border-radius:3px; cursor:pointer; transition:all 0.2s;
}
.btn-back:hover { border-color:var(--gold); background:var(--gold-dim); }

/* SUCCESS */
.success-wrap { text-align:center; padding:40px 24px; }
.success-icon { font-size:48px; margin-bottom:16px; }
.success-title { font-family:'Cormorant Garamond',serif; font-size:34px; font-weight:600; color:var(--text); margin-bottom:12px; }
.success-text { font-size:13px; line-height:1.9; color:var(--muted); margin-bottom:28px; }
.success-detail { font-size:11px; color:var(--gold); letter-spacing:2px; text-transform:uppercase; opacity:0.8; }
</style>
</head>
<body>

<div class="header">
  <div class="logo">HS <span>Personal</span> Trainer</div>
  <div style="font-size:9px;letter-spacing:3px;color:var(--muted);text-transform:uppercase">Bilan offert</div>
</div>

<!-- PROGRESS BAR -->
<div class="progress-wrap" id="progress-wrap" style="display:none">
  <div class="progress-top">
    <span class="progress-label" id="progress-label">Étape 1 sur 3</span>
    <span class="progress-fraction" id="progress-frac">Profil</span>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:33%"></div></div>
</div>

<!-- SCREEN 0 : MERCI + INTRO -->
<div class="screen active" id="screen-0">
  <div style="padding-top:40px;text-align:center">
    <div class="thankyou-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5"><path d="M20 6L9 17l-5-5"/></svg>
