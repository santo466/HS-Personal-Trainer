  <input type="hidden" name="sports_pratiques" id="f-sports">
  <input type="hidden" name="blessures_douleurs" id="f-blessures">
  <input type="hidden" name="restrictions_medicales" id="f-restrictions">
  <input type="hidden" name="motivation_pourquoi" id="f-why">
  <input type="hidden" name="motivation_blocage" id="f-blocage">
  <input type="hidden" name="score_motivation" id="f-motivation">
  <input type="hidden" name="_subject" id="f-subject" value="🏋️ Nouveau bilan HS Personal Trainer">
  <input type="hidden" name="_replyto" id="f-replyto">
</form>

<script>
var currentScreen = 0;
var pillData = {};
var objData = [];

// Get URL params (prenom, nom, tel, email passed from main site)
var params = new URLSearchParams(window.location.search);
var prospect = {
  prenom: params.get('prenom') || '',
  nom: params.get('nom') || '',
  tel: params.get('tel') || '',
  email: params.get('email') || ''
};

function goTo(n) {
  document.getElementById('screen-' + currentScreen).classList.remove('active');
  currentScreen = n;
  document.getElementById('screen-' + n).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });

  var pw = document.getElementById('progress-wrap');
  var pf = document.getElementById('progress-fill');
  var pl = document.getElementById('progress-label');
  var pfrac = document.getElementById('progress-frac');
  var labels = ['', 'Profil', 'Mode de vie & Sport', 'Santé & Motivation'];
  var pcts = ['', '33%', '66%', '100%'];

  if (n >= 1 && n <= 3) {
    pw.style.display = 'block';
    pl.textContent = 'Étape ' + n + ' sur 3';
    pfrac.textContent = labels[n];
    pf.style.width = pcts[n];
  } else {
    pw.style.display = 'none';
  }
}

function togglePill(el) {
  var field = el.dataset.field;
  // Radio behavior for pills and scale-btn
  document.querySelectorAll('[data-field="' + field + '"]').forEach(function(b) { b.classList.remove('active'); });
  el.classList.add('active');
  pillData[field] = el.dataset.val;
}

function toggleObj(el) {
  el.classList.toggle('active');
}

function getObjValues() {
  var vals = [];
  document.querySelectorAll('.obj-card.active').forEach(function(el) { vals.push(el.dataset.val); });
  return vals.join(', ');
}

function submitForm() {
  // Populate hidden form
  document.getElementById('f-prenom').value = prospect.prenom;
  document.getElementById('f-nom').value = prospect.nom;
  document.getElementById('f-tel').value = prospect.tel;
  document.getElementById('f-email').value = prospect.email;
  document.getElementById('f-replyto').value = prospect.email;
  document.getElementById('f-age').value = document.getElementById('age').value;
  document.getElementById('f-sexe').value = pillData['sexe'] || '';
  document.getElementById('f-taille').value = document.getElementById('taille').value;
  document.getElementById('f-poids').value = document.getElementById('poids').value;
  document.getElementById('f-profession').value = document.getElementById('profession').value;
  document.getElementById('f-objectifs').value = getObjValues();
  document.getElementById('f-repas').value = pillData['repas'] || '';
  document.getElementById('f-eau').value = pillData['eau'] || '';
  document.getElementById('f-activpro').value = pillData['activ-pro'] || '';
  document.getElementById('f-sommeil').value = pillData['sommeil'] || '';
  document.getElementById('f-stress').value = pillData['stress'] || '';
  document.getElementById('f-exp').value = pillData['exp'] || '';
  document.getElementById('f-freq').value = pillData['freq'] || '';
  document.getElementById('f-salle').value = pillData['salle'] || '';
  document.getElementById('f-sports').value = document.getElementById('sports').value;
  document.getElementById('f-blessures').value = document.getElementById('blessures').value;
  document.getElementById('f-restrictions').value = document.getElementById('restrictions').value;
  document.getElementById('f-why').value = document.getElementById('motivation-why').value;
  document.getElementById('f-blocage').value = document.getElementById('motivation-blocage').value;
  document.getElementById('f-motivation').value = pillData['motivation'] || '';
  document.getElementById('f-subject').value = '🏋️ Bilan — ' + prospect.prenom + ' ' + prospect.nom;

  var form = document.getElementById('formspree-form');
  var data = new FormData(form);

  fetch('https://formspree.io/f/xaqzwvqd', {
    method: 'POST',
    body: data,
    headers: { 'Accept': 'application/json' }
  }).then(function(res) {
    goTo('success');
    document.getElementById('progress-wrap').style.display = 'none';
  }).catch(function() {
    goTo('success'); // Show success anyway
    document.getElementById('progress-wrap').style.display = 'none';
  });
}
</script>
</body>
