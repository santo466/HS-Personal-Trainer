      <div class="pill" data-field="freq" data-val="3-4/sem" onclick="togglePill(this)">3-4 / sem</div>
      <div class="pill" data-field="freq" data-val="5+/sem" onclick="togglePill(this)">5+ / sem</div>
    </div>
  </div>

  <div class="field"><label>Accès salle de sport</label>
    <div class="pills">
      <div class="pill" data-field="salle" data-val="Oui" onclick="togglePill(this)">Oui</div>
      <div class="pill" data-field="salle" data-val="Non" onclick="togglePill(this)">Non</div>
      <div class="pill" data-field="salle" data-val="Domicile" onclick="togglePill(this)">Domicile uniquement</div>
    </div>
  </div>

  <div class="field"><label>Sports pratiqués</label><input type="text" id="sports" placeholder="Ex : Football, natation..."></div>

  <div class="nav-btns">
    <button class="btn-back" onclick="goTo(1)">← Retour</button>
    <button class="btn-next" onclick="goTo(3)">Continuer →</button>
  </div>
</div>

<!-- SCREEN 3 : SANTÉ + MOTIVATION -->
<div class="screen" id="screen-3">
  <p class="step-eyebrow">Étape 3 sur 3</p>
  <h2 class="step-title">Santé & Motivation</h2>
  <p class="step-sub">Dernière étape — vos réponses restent confidentielles.</p>

  <div class="section-label">Santé</div>

  <div class="field"><label>Blessures passées ou douleurs actuelles</label><textarea id="blessures" placeholder="Ex : Entorse genou, douleur lombaire..."></textarea></div>
  <div class="field"><label>Restrictions médicales ou traitements</label><textarea id="restrictions" placeholder="Ex : Aucune / Traitement pour..."></textarea></div>

  <div class="section-label">Motivation</div>

  <div class="field"><label>Pourquoi souhaitez-vous atteindre cet objectif ?</label><textarea id="motivation-why" placeholder="Racontez-nous en quelques mots..."></textarea></div>
  <div class="field"><label>Qu'est-ce qui vous empêche d'y arriver aujourd'hui ?</label><textarea id="motivation-blocage" placeholder="Manque de temps, de motivation..."></textarea></div>

  <div class="field"><label>Niveau de motivation (1 → 10)</label>
    <div class="scale">
      <div class="scale-btn" data-field="motivation" data-val="1" onclick="togglePill(this)">1</div>
      <div class="scale-btn" data-field="motivation" data-val="2" onclick="togglePill(this)">2</div>
      <div class="scale-btn" data-field="motivation" data-val="3" onclick="togglePill(this)">3</div>
      <div class="scale-btn" data-field="motivation" data-val="4" onclick="togglePill(this)">4</div>
      <div class="scale-btn" data-field="motivation" data-val="5" onclick="togglePill(this)">5</div>
      <div class="scale-btn" data-field="motivation" data-val="6" onclick="togglePill(this)">6</div>
      <div class="scale-btn" data-field="motivation" data-val="7" onclick="togglePill(this)">7</div>
      <div class="scale-btn" data-field="motivation" data-val="8" onclick="togglePill(this)">8</div>
      <div class="scale-btn" data-field="motivation" data-val="9" onclick="togglePill(this)">9</div>
      <div class="scale-btn" data-field="motivation" data-val="10" onclick="togglePill(this)">10</div>
    </div>
    <div class="scale-labels"><span>Faible</span><span>Maximum</span></div>
  </div>

  <div class="nav-btns">
    <button class="btn-back" onclick="goTo(2)">← Retour</button>
    <button class="btn-next" onclick="submitForm()">Envoyer mon bilan →</button>
  </div>
</div>

<!-- SCREEN SUCCESS -->
<div class="screen" id="screen-success">
  <div class="success-wrap">
    <div class="success-icon">✦</div>
    <h2 class="success-title">Bilan reçu !</h2>
    <div class="divider"></div>
    <p class="success-text">
      Merci d'avoir pris le temps de remplir ce questionnaire.<br><br>
      J'analyse vos réponses et vous contacte très rapidement pour convenir d'un rendez-vous de bilan physique.<br><br>
      <strong style="color:var(--gold)">À très bientôt,</strong><br>
      <strong style="color:var(--gold)">Hélio — HS Personal Trainer</strong>
    </p>
    <p class="success-detail">Vous serez contacté sous 24-48h</p>
  </div>
</div>

<!-- HIDDEN FORMSPREE FORM -->
<form id="formspree-form" action="https://formspree.io/f/xaqzwvqd" method="POST" style="display:none">
  <input type="hidden" name="prenom" id="f-prenom">
  <input type="hidden" name="nom" id="f-nom">
  <input type="hidden" name="telephone" id="f-tel">
  <input type="hidden" name="email" id="f-email">
  <input type="hidden" name="age" id="f-age">
  <input type="hidden" name="sexe" id="f-sexe">
  <input type="hidden" name="taille" id="f-taille">
  <input type="hidden" name="poids" id="f-poids">
  <input type="hidden" name="profession" id="f-profession">
  <input type="hidden" name="objectifs" id="f-objectifs">
  <input type="hidden" name="repas_jour" id="f-repas">
  <input type="hidden" name="hydratation" id="f-eau">
  <input type="hidden" name="activite_pro" id="f-activpro">
  <input type="hidden" name="sommeil" id="f-sommeil">
  <input type="hidden" name="stress" id="f-stress">
  <input type="hidden" name="experience_muscu" id="f-exp">
  <input type="hidden" name="frequence_entrainement" id="f-freq">
