  </div>
</div>

<!-- SCREEN 1 : PROFIL -->
<div class="screen" id="screen-1">
  <p class="step-eyebrow">Étape 1 sur 3</p>
  <h2 class="step-title">Votre profil</h2>
  <p class="step-sub">Quelques informations pour personnaliser votre accompagnement.</p>

  <div class="grid2">
    <div class="field"><label>Âge</label><input type="number" id="age" placeholder="Ex : 28"></div>
    <div class="field"><label>Sexe</label>
