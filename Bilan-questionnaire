    <div class="obj-card" data-field="obj" data-val="Prise de masse" onclick="toggleObj(this)"><div class="lbl">Prise de masse</div></div>
    <div class="obj-card" data-field="obj" data-val="Remise en forme" onclick="toggleObj(this)"><div class="lbl">Remise en forme</div></div>
    <div class="obj-card" data-field="obj" data-val="Performance" onclick="toggleObj(this)"><div class="lbl">Performance sportive</div></div>
    <div class="obj-card" data-field="obj" data-val="Réathlétisation" onclick="toggleObj(this)"><div class="lbl">Réathlétisation</div></div>
    <div class="obj-card" data-field="obj" data-val="Autre" onclick="toggleObj(this)"><div class="lbl">Autre</div></div>
  </div>

  <div class="nav-btns"><button class="btn-next" onclick="goTo(2)">Continuer →</button></div>
</div>

<!-- SCREEN 2 : MODE DE VIE + SPORT -->
<div class="screen" id="screen-2">
  <p class="step-eyebrow">Étape 2 sur 3</p>
  <h2 class="step-title">Mode de vie & Sport</h2>
  <p class="step-sub">Pour adapter votre programme à votre quotidien.</p>

  <div class="section-label">Mode de vie</div>

  <div class="field"><label>Repas par jour</label>
    <div class="pills">
      <div class="pill" data-field="repas" data-val="2" onclick="togglePill(this)">2</div>
      <div class="pill" data-field="repas" data-val="3" onclick="togglePill(this)">3</div>
      <div class="pill" data-field="repas" data-val="4" onclick="togglePill(this)">4</div>
      <div class="pill" data-field="repas" data-val="5+" onclick="togglePill(this)">5+</div>
    </div>
  </div>

  <div class="grid2">
    <div class="field"><label>Hydratation / jour</label>
      <div class="pills">
        <div class="pill" data-field="eau" data-val="Moins 1L" onclick="togglePill(this)">- 1L</div>
        <div class="pill" data-field="eau" data-val="1-2L" onclick="togglePill(this)">1-2L</div>
        <div class="pill" data-field="eau" data-val="Plus 2L" onclick="togglePill(this)">+ 2L</div>
      </div>
    </div>
    <div class="field"><label>Activité professionnelle</label>
      <div class="pills">
        <div class="pill" data-field="activ-pro" data-val="Sédentaire" onclick="togglePill(this)">Sédentaire</div>
        <div class="pill" data-field="activ-pro" data-val="Modérée" onclick="togglePill(this)">Modérée</div>
        <div class="pill" data-field="activ-pro" data-val="Active" onclick="togglePill(this)">Active</div>
      </div>
    </div>
  </div>

  <div class="grid2">
    <div class="field"><label>Qualité du sommeil</label>
      <div class="scale">
        <div class="scale-btn" data-field="sommeil" data-val="1" onclick="togglePill(this)">1</div>
        <div class="scale-btn" data-field="sommeil" data-val="2" onclick="togglePill(this)">2</div>
        <div class="scale-btn" data-field="sommeil" data-val="3" onclick="togglePill(this)">3</div>
        <div class="scale-btn" data-field="sommeil" data-val="4" onclick="togglePill(this)">4</div>
        <div class="scale-btn" data-field="sommeil" data-val="5" onclick="togglePill(this)">5</div>
      </div>
      <div class="scale-labels"><span>Mauvais</span><span>Excellent</span></div>
    </div>
    <div class="field"><label>Niveau de stress</label>
      <div class="scale">
        <div class="scale-btn" data-field="stress" data-val="1" onclick="togglePill(this)">1</div>
        <div class="scale-btn" data-field="stress" data-val="2" onclick="togglePill(this)">2</div>
        <div class="scale-btn" data-field="stress" data-val="3" onclick="togglePill(this)">3</div>
        <div class="scale-btn" data-field="stress" data-val="4" onclick="togglePill(this)">4</div>
        <div class="scale-btn" data-field="stress" data-val="5" onclick="togglePill(this)">5</div>
      </div>
      <div class="scale-labels"><span>Faible</span><span>Élevé</span></div>
    </div>
  </div>

  <div class="section-label">Sport</div>

  <div class="field"><label>Expérience musculation</label>
    <div class="pills">
      <div class="pill" data-field="exp" data-val="Aucune" onclick="togglePill(this)">Aucune</div>
      <div class="pill" data-field="exp" data-val="Débutant" onclick="togglePill(this)">Débutant</div>
      <div class="pill" data-field="exp" data-val="Intermédiaire" onclick="togglePill(this)">Intermédiaire</div>
      <div class="pill" data-field="exp" data-val="Avancé" onclick="togglePill(this)">Avancé</div>
    </div>
  </div>

  <div class="field"><label>Fréquence d'entraînement</label>
